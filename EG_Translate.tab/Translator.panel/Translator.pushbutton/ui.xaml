<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EG Translator v2.4 PRO" Height="760" Width="1280" MinWidth="980" MinHeight="620" MaxWidth="1600" MaxHeight="980" WindowStartupLocation="CenterScreen" ResizeMode="CanResize" SizeToContent="Manual" WindowState="Normal" Background="#F4F6FA">
    <Window.Resources>
        <Style TargetType="GroupBox"><Setter Property="Margin" Value="0,0,0,10"/><Setter Property="Padding" Value="10"/></Style>
        <Style x:Key="Btn" TargetType="Button"><Setter Property="Height" Value="32"/><Setter Property="MinWidth" Value="92"/><Setter Property="Margin" Value="0,0,8,0"/></Style>
        <Style TargetType="CheckBox"><Setter Property="Margin" Value="0,0,0,6"/></Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions><ColumnDefinition x:Name="LeftPanelColumn" Width="320" MinWidth="260"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"><StackPanel>
            <Border Background="White" BorderBrush="#D8DCE7" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,10"><StackPanel><TextBlock Text="EG Translator v2.4 PRO" FontSize="18" FontWeight="Bold"/><TextBlock x:Name="DocLabel" Margin="0,6,0,0" Foreground="#475467" Text="—" TextWrapping="Wrap"/></StackPanel></Border>
            <GroupBox x:Name="GbUi" Header="Arayüz Dili"><StackPanel Orientation="Horizontal"><CheckBox x:Name="UiTR" Content="TR" IsChecked="True" Margin="0,0,14,0"/><CheckBox x:Name="UiEN" Content="EN"/></StackPanel></GroupBox>
            <GroupBox x:Name="GbDirection" Header="Çeviri Yönü"><StackPanel><TextBlock Text="Source" Margin="0,0,0,6"/><WrapPanel><ToggleButton x:Name="SrcTR" Content="TR" IsChecked="True" Width="56" Height="28" Margin="0,0,8,8"/><ToggleButton x:Name="SrcEN" Content="EN" Width="56" Height="28" Margin="0,0,8,8"/><ToggleButton x:Name="SrcES" Content="ES" Width="56" Height="28" Margin="0,0,8,8"/><ToggleButton x:Name="SrcPT" Content="PT" Width="56" Height="28" Margin="0,0,8,8"/><ToggleButton x:Name="SrcRU" Content="RU" Width="56" Height="28" Margin="0,0,8,8"/></WrapPanel><TextBlock Text="Target" Margin="0,4,0,6"/><WrapPanel><ToggleButton x:Name="TgtTR" Content="TR" Width="56" Height="28" Margin="0,0,8,8"/><ToggleButton x:Name="TgtEN" Content="EN" IsChecked="True" Width="56" Height="28" Margin="0,0,8,8"/><ToggleButton x:Name="TgtES" Content="ES" Width="56" Height="28" Margin="0,0,8,8"/><ToggleButton x:Name="TgtPT" Content="PT" Width="56" Height="28" Margin="0,0,8,8"/><ToggleButton x:Name="TgtRU" Content="RU" Width="56" Height="28" Margin="0,0,8,8"/></WrapPanel></StackPanel></GroupBox>
            <GroupBox x:Name="GbScope" Header="Kapsam"><StackPanel><RadioButton x:Name="ScopeCurrent" Content="Aktif Belge" IsChecked="True"/><RadioButton x:Name="ScopeSelection" Content="Seçili Elemanlar"/><RadioButton x:Name="ScopeFolder" Content="Klasördeki RFA Dosyaları"/><StackPanel Orientation="Horizontal" Margin="18,6,0,0"><Button x:Name="BtnPickFolder" Click="BtnPickFolder_Click" Content="Klasör Seç" Style="{StaticResource Btn}"/><TextBox x:Name="TxtFolder" Width="180" Padding="6,4"/></StackPanel></StackPanel></GroupBox>
            <GroupBox x:Name="GbItems" Header="Çeviri Kalemleri"><StackPanel><CheckBox x:Name="ItRoomNames" Content="Room Names"/><CheckBox x:Name="ItTextNotes" Content="Text Notes"/><CheckBox x:Name="ItMaterialNames" Content="Material Names"/><CheckBox x:Name="ItLevels" Content="Levels"/><CheckBox x:Name="ItViews" Content="View Names"/><CheckBox x:Name="ItSchedules" Content="Schedule Names"/><CheckBox x:Name="ItSheets" Content="Sheet Names"/><CheckBox x:Name="ItFamiliesTypes" Content="Families and Types Names"/><CheckBox x:Name="ItFamilyParams" Content="Family Parameters"/><CheckBox x:Name="ItProjectParams" Content="Project Parameters"/><CheckBox x:Name="ItGlobalParams" Content="Global Parameters"/></StackPanel></GroupBox>
            <GroupBox x:Name="GbFamilyFilters" Header="Aile Kategori Filtresi"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBox x:Name="FamilyFilterSearchBox" Grid.Row="0" Margin="0,0,0,8" Padding="6,4" ToolTip="Kategori ara"/><WrapPanel Grid.Row="1" Margin="0,0,0,6"><Button x:Name="BtnFamilyAll" Click="BtnFamilyAll_Click" Content="Tüm" Height="28" MinWidth="62" Margin="0,0,6,6"/><Button x:Name="BtnFamilyNone" Click="BtnFamilyNone_Click" Content="Temizle" Height="28" MinWidth="62" Margin="0,0,6,6"/><Button x:Name="BtnFamilyArch" Click="BtnFamilyArch_Click" Content="Mimari" Height="28" MinWidth="66" Margin="0,0,6,6"/><Button x:Name="BtnFamilyMEP" Click="BtnFamilyMEP_Click" Content="MEP" Height="28" MinWidth="60" Margin="0,0,6,6"/><Button x:Name="BtnFamilyStruct" Click="BtnFamilyStruct_Click" Content="Statik" Height="28" MinWidth="60" Margin="0,0,6,6"/></WrapPanel><WrapPanel Grid.Row="2" Margin="0,0,0,8"><Button x:Name="BtnFamilyInfra" Click="BtnFamilyInfra_Click" Content="Altyapı" Height="28" MinWidth="68" Margin="0,0,6,6"/><Button x:Name="BtnFamilyLandscape" Click="BtnFamilyLandscape_Click" Content="Peyzaj" Height="28" MinWidth="68" Margin="0,0,6,6"/><TextBlock x:Name="FamilyFilterCountText" Margin="10,5,0,0" Foreground="#667085" VerticalAlignment="Center"/></WrapPanel><ListBox x:Name="FamilyFilterBox" Grid.Row="3" Height="260" BorderThickness="0"/></Grid></GroupBox>
            <GroupBox x:Name="GbReport" Header="Rapor Ayarları"><StackPanel><CheckBox x:Name="OptDictionary" Content="Dictionary First" IsChecked="True"/><CheckBox x:Name="OptApi" Content="Use Free API (MyMemory)" IsChecked="False"/><CheckBox x:Name="OptCache" Content="Cache Enabled" IsChecked="True"/><CheckBox x:Name="OptSmart" Content="Smart Split" IsChecked="True"/><CheckBox x:Name="OptHtml" Content="HTML Report" IsChecked="True"/><Separator Margin="0,6,0,6"/><RadioButton x:Name="ReportDesktop" Content="Desktop" IsChecked="True"/><RadioButton x:Name="ReportDocuments" Content="Documents"/><RadioButton x:Name="ReportCustom" Content="Custom Folder"/><StackPanel Orientation="Horizontal" Margin="18,6,0,0"><Button x:Name="BtnPickReportFolder" Click="BtnPickReportFolder_Click" Content="Klasör Seç" Style="{StaticResource Btn}"/><TextBox x:Name="TxtReportFolder" Width="180" Padding="6,4"/></StackPanel></StackPanel></GroupBox>
            <GroupBox x:Name="GbFamilySave" Header="Aile Kayıt Ayarları"><StackPanel>
                <TextBlock Text="Proje ailesi parametreleri değiştirildiğinde aile yeniden kaydedilip projeye yüklenir. Klasör, prefix ve suffix tanımlayabilirsiniz." TextWrapping="Wrap" Foreground="#667085" Margin="0,0,0,8" FontSize="11"/>
                <TextBlock Text="Kayıt Klasörü" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BtnPickFamilySaveFolder" Click="BtnPickFamilySaveFolder_Click" Content="Klasör Seç" Style="{StaticResource Btn}"/>
                    <TextBox x:Name="TxtFamilySaveFolder" Width="160" Padding="6,4" ToolTip="Boş bırakılırsa %TEMP% kullanılır."/>
                </StackPanel>
                <TextBlock Text="Dosya Adı: {Prefix}AileAdı{Suffix}.rfa" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="46"/><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Prefix" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TxtFamilyPrefix" Padding="6,4" Margin="0,0,8,0" ToolTip="Boş bırakılabilir. Örn: TR_"/>
                    <TextBlock Grid.Column="2" Text="Suffix" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="3" x:Name="TxtFamilySuffix" Padding="6,4" ToolTip="Boş bırakılabilir. Örn: _ceviri"/>
                </Grid>
                <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="4" Padding="8,6">
                    <TextBlock x:Name="TxtFamilySavePreview" Text="{}{prefix}AileAdı{suffix}.rfa" FontSize="11" Foreground="#1D4ED8" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>
            </StackPanel></GroupBox>
        </StackPanel></ScrollViewer>
        <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#D8DCE7" ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" ShowsPreview="True" />
        <Grid Grid.Column="2"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <TabControl Grid.Row="0" Margin="0,0,0,8">
                <TabItem Header="Preview"><Grid Margin="10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><WrapPanel Grid.Row="0" Margin="0,0,0,6"><Button x:Name="BtnSelectAll" Click="BtnSelectAll_Click" Content="Tümünü Seç" Style="{StaticResource Btn}"/><Button x:Name="BtnSelectNone" Click="BtnSelectNone_Click" Content="Seçimi Kaldır" Style="{StaticResource Btn}"/><Button x:Name="BtnSelectChanged" Click="BtnSelectChanged_Click" Content="Sadece Değişenler" Style="{StaticResource Btn}"/><Button x:Name="BtnExportExcel" Click="BtnExportExcel_Click" Content="XML Dışa Aktar" Style="{StaticResource Btn}"/><Button x:Name="BtnImportExcel" Click="BtnImportExcel_Click" Content="XML İçe Al" Style="{StaticResource Btn}"/><Button x:Name="BtnValidateManual" Click="BtnValidateManual_Click" Content="Manual Kontrol" Style="{StaticResource Btn}"/><TextBlock Text="Filtre" VerticalAlignment="Center" Margin="12,0,6,0"/><TextBox x:Name="FilterBox" Width="200" Padding="6,4"/></WrapPanel><WrapPanel Grid.Row="1" Margin="0,0,0,8" Background="#F8FAFF" ><TextBlock Text="Current:" VerticalAlignment="Center" Margin="6,0,6,0" Foreground="#374151"/><TextBox x:Name="PreviewPrefixFromBox" Width="140" Padding="6,4" ToolTip="Değiştirilecek metin (Current sütununda arar). Örn: 3D.MS_"/><TextBlock Text="→" VerticalAlignment="Center" Margin="8,0,8,0" FontWeight="Bold" Foreground="#6366F1"/><TextBox x:Name="PreviewPrefixToBox" Width="140" Padding="6,4" ToolTip="Yerine yazılacak metin. Örn: EG_ (boş bırakılırsa siler)"/><Button x:Name="BtnPreviewReplacePrefix" Click="BtnPreviewReplacePrefix_Click" Content="Manual Uygula" Style="{StaticResource Btn}" Margin="8,0,0,0"/><Button x:Name="BtnPreviewClearManual" Click="BtnPreviewClearManual_Click" Content="Manual Temizle" Style="{StaticResource Btn}"/><TextBlock x:Name="PreviewReplaceSummary" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#6B7280" FontSize="11"/></WrapPanel><DataGrid Grid.Row="2" x:Name="PlanGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="False" AlternatingRowBackground="#F9FAFB" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderBrush="#D8DCE7" BorderThickness="1"><DataGrid.Columns><DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected, Mode=TwoWay}" Width="36"/><DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="90" IsReadOnly="True"/><DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="140" IsReadOnly="True"/><DataGridTextColumn Header="Item" Binding="{Binding ItemKind}" Width="150" IsReadOnly="True"/><DataGridTextColumn Header="Current" Binding="{Binding Current}" Width="220" IsReadOnly="True"/><DataGridTextColumn Header="Suggested" Binding="{Binding Suggested}" Width="220" IsReadOnly="True"/><DataGridTemplateColumn Header="Manual" Width="220"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Manual}" /></DataTemplate></DataGridTemplateColumn.CellTemplate><DataGridTemplateColumn.CellEditingTemplate><DataTemplate><TextBox Text="{Binding Manual, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" /></DataTemplate></DataGridTemplateColumn.CellEditingTemplate></DataGridTemplateColumn><DataGridTextColumn Header="Final" Binding="{Binding Final}" Width="220" IsReadOnly="True"/><DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="90" IsReadOnly="True"/><DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="110" IsReadOnly="True"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="180" IsReadOnly="True"/></DataGrid.Columns></DataGrid></Grid></TabItem>
                <TabItem Header="Parameters"><Grid Margin="10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Grid.Row="0" Text="Built-in / shared / kilitli parametreler burada Create+Map planı olarak listelenir." Foreground="#667085" Margin="0,0,0,8"/><WrapPanel Grid.Row="1" Margin="0,0,0,8"><Button x:Name="BtnParamSelectAll" Click="BtnParamSelectAll_Click" Content="Tümünü Seç" Style="{StaticResource Btn}"/><Button x:Name="BtnParamSelectNone" Click="BtnParamSelectNone_Click" Content="Seçimi Kaldır" Style="{StaticResource Btn}"/><TextBlock Text="Prefix From" VerticalAlignment="Center" Margin="10,0,6,0"/><TextBox x:Name="ParamPrefixFromBox" Width="150" Padding="6,4"/><TextBlock Text="To" VerticalAlignment="Center" Margin="8,0,6,0"/><TextBox x:Name="ParamPrefixToBox" Width="130" Padding="6,4"/><Button x:Name="BtnParamReplacePrefix" Click="BtnParamReplacePrefix_Click" Content="Prefix Değiştir" Style="{StaticResource Btn}"/><Button x:Name="BtnParamClearManual" Click="BtnParamClearManual_Click" Content="Manual Temizle" Style="{StaticResource Btn}"/></WrapPanel><DataGrid Grid.Row="2" x:Name="ParamMapGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="False" AlternatingRowBackground="#F9FAFB" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderBrush="#D8DCE7" BorderThickness="1"><DataGrid.Columns><DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected, Mode=TwoWay}" Width="36"/><DataGridTextColumn Header="Source Param" Binding="{Binding SourceParam}" Width="180" IsReadOnly="True"/><DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="80" IsReadOnly="True"/><DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" IsReadOnly="True"/><DataGridTextColumn Header="Param Scope" Binding="{Binding ParamType}" Width="100" IsReadOnly="True"/><DataGridTextColumn Header="Value Sample" Binding="{Binding ValueSample}" Width="140" IsReadOnly="True"/><DataGridTextColumn Header="Target Param" Binding="{Binding TargetParam}" Width="220" IsReadOnly="True"/><DataGridTemplateColumn Header="Manual Target Param" Width="220"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding ManualTarget}" /></DataTemplate></DataGridTemplateColumn.CellTemplate><DataGridTemplateColumn.CellEditingTemplate><DataTemplate><TextBox Text="{Binding ManualTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" /></DataTemplate></DataGridTemplateColumn.CellEditingTemplate></DataGridTemplateColumn><DataGridTextColumn Header="Final Target" Binding="{Binding FinalTarget}" Width="220" IsReadOnly="True"/><DataGridTextColumn Header="Bind Type" Binding="{Binding BindingType}" Width="100" IsReadOnly="True"/><DataGridTextColumn Header="Param Group" Binding="{Binding ParameterGroup}" Width="180" IsReadOnly="True"/><DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="120" IsReadOnly="True"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="160" IsReadOnly="True"/></DataGrid.Columns></DataGrid></Grid></TabItem>
                <TabItem Header="Report"><Grid Margin="10"><TextBlock TextWrapping="Wrap" Text="HTML rapor varsayılan olarak Desktop'a yazılır. İsterseniz soldan Documents veya Custom Folder seçebilirsiniz. Rapor; rename önizlemesi, create+map planı ve hata listesini içerir."/></Grid></TabItem>
            </TabControl>
            <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center" Text="Hazır" Foreground="#667085"/><Button x:Name="BtnScan" Grid.Column="1" Click="BtnScan_Click" Content="Tara" Style="{StaticResource Btn}" Background="#2563EB" Foreground="White"/><Button x:Name="BtnReport" Grid.Column="2" Click="BtnReport_Click" Content="HTML Rapor" Style="{StaticResource Btn}"/><Button x:Name="BtnCancel" Grid.Column="3" Click="BtnCancel_Click" Content="İptal" Style="{StaticResource Btn}"/><Button x:Name="BtnApply" Grid.Column="4" Click="BtnApply_Click" Content="Uygula" Style="{StaticResource Btn}" Background="#059669" Foreground="White"/></Grid>
        </Grid>
    </Grid>
</Window>
